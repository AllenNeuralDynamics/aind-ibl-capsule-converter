{
	"version": 1,
	"base_image": "codeocean/mambaforge3:24.5.0-0-python3.12.4-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"apt": {
			"packages": [
				{
					"name": "build-essential",
					"version": "12.9ubuntu3"
				},
				{
					"name": "ca-certificates",
					"version": "20240203~22.04.1"
				},
				{
					"name": "curl",
					"version": "7.81.0-1ubuntu1.23"
				},
				{
					"name": "debhelper"
				},
				{
					"name": "devscripts"
				},
				{
					"name": "equivs"
				},
				{
					"name": "fakeroot"
				},
				{
					"name": "git",
					"version": "1:2.34.1-1ubuntu1.17"
				},
				{
					"name": "pkg-config"
				},
				{
					"name": "tree",
					"version": "2.0.2-1"
				}
			],
			"install_software_properties_common": true
		}
	}
}