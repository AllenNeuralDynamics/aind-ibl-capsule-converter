{
	"version": 1,
	"base_image": "codeocean/mambaforge3:24.5.0-0-python3.12.4-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"apt": {
			"packages": [
				{
					"name": "build-essential"
				},
				{
					"name": "ca-certificates"
				},
				{
					"name": "curl"
				},
				{
					"name": "debhelper"
				},
				{
					"name": "devscripts"
				},
				{
					"name": "dpkg-dev"
				},
				{
					"name": "equivs"
				},
				{
					"name": "fakeroot"
				},
				{
					"name": "git"
				},
				{
					"name": "pkg-config"
				},
				{
					"name": "tree"
				}
			],
			"install_software_properties_common": true
		},
		"vscode": {
			"packages": [
				{
					"name": "ms-python.python",
					"version": "2025.14.0"
				},
				{
					"name": "ms-toolsai.jupyter",
					"version": "2025.4.1"
				},
				{
					"name": "reditorsupport.r",
					"version": "2.8.6"
				},
				{
					"name": "saoudrizwan.claude-dev",
					"version": "3.35.1"
				}
			],
			"version": "4.100.3"
		}
	}
}