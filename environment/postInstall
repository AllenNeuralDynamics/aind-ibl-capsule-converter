#!/usr/bin/env bash
set -Eeuo pipefail

export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y --no-install-recommends \
  build-essential devscripts debhelper equivs fakeroot dpkg-dev \
  curl ca-certificates git pkg-config

# Install wavpack 5.8.1 from debian package
workdir="$(mktemp -d)"
pushd "$workdir"

dget -u https://deb.debian.org/debian/pool/main/w/wavpack/wavpack_5.8.1-1.dsc
cd wavpack-5.8.1
mk-build-deps -i -r -t "apt-get -y --no-install-recommends" debian/control
DEB_BUILD_OPTIONS=nocheck debuild -us -uc -b
apt-get install -y ../wavpack_5.8.1-1_*.deb ../libwavpack1_5.8.1-1_*.deb ../libwavpack-dev_5.8.1-1_*.deb

popd

apt-get purge -y devscripts debhelper equivs fakeroot pkg-config
apt-get autoremove -y --purge
rm -rf "$workdir" /var/lib/apt/lists/*

# Verify
wavpack --version

curl -LsSf https://astral.sh/uv/install.sh | sh

cat > requirements.txt <<'REQ'
numpy>=1.21.0
pandas>=1.3.0
matplotlib>=3.5.0
zarr>=2.10.0
antspyx>=0.3.0
iblatlas>=0.4.0
aind-anatomical-utils>=0.4,<0.5
aind-mri-utils>=0.1.0
aind-ephys-ibl-gui-conversion @ git+https://github.com/AllenNeuralDynamics/aind-ephys-ibl-gui-conversion@main
aind-registration-utils>=0.4,<0.5
aind-s3-cache>=0.1
aind-zarr-utils>=0.11.5
REQ

uv pip install --no-cache --system -r requirements.txt
